# Snowflake FinOps Toolkit - Environment Variables Template
# Copy this file to .env and fill in your actual values
# IMPORTANT: .env is in .gitignore — never commit real credentials to GitHub

# ── Required ──────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your_org-your_account
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password

# ── Optional (defaults shown) ─────────────────────────────────────────────────
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=FINOPS_DEMO
SNOWFLAKE_SCHEMA=FINOPS_SAMPLE
SNOWFLAKE_ROLE=SYSADMIN

# ── Key-Pair Authentication (alternative to password) ────────────────────────
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_passphrase
