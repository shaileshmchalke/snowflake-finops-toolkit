# =============================================================================
# Snowflake FinOps Toolkit — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is in .gitignore.
# =============================================================================

# ── Snowflake Account ──────────────────────────────────────────────────────
# Format: <org>-<account>  OR  <locator>.<region>.<cloud>
# Example: myorg-myaccount  OR  xy12345.us-east-1.aws
SNOWFLAKE_ACCOUNT=your_account_identifier

# ── Authentication ─────────────────────────────────────────────────────────
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password

# ── Key-Pair Auth (Optional — for service accounts) ───────────────────────
# Leave blank to use password auth above
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# ── Connection Defaults ────────────────────────────────────────────────────
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=FINOPS_DEMO
SNOWFLAKE_SCHEMA=FINOPS_SAMPLE
SNOWFLAKE_ROLE=SYSADMIN

# ── Application Settings ───────────────────────────────────────────────────
# Credit price in USD (on-demand default: 3.00)
CREDIT_PRICE_USD=3.00

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO