*.env
.env.local
.env.production
secrets/
*.pem
*.p8
*.key

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-wheel-metadata/

# ── Virtual Environments ──────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.virtualenv/

# ── Testing ───────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.coveragerc
coverage.xml
nosetests.xml
test-results/

# ── IDE / Editors ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.DS_Store
Thumbs.db
.project
.classpath

# ── Streamlit ─────────────────────────────────────────────────────────────
